-- FPS & Ping Loop (Sicherer gemacht)
task.spawn(function()
    while true do
        local fps = math.floor(1 / RunService.RenderStepped:Wait())
        fpsLabel.Text = "FPS: " .. fps
        local p = game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValueString()
        local pingValue = p:match("%d+") or "0"
        pingLabel.Text = "Ping: " .. pingValue .. "ms"
        task.wait(1)
    end
end)

-- Drag Funktion
local function makeDraggable(frame)
    local dragging, dragInput, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    frame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
end

-- Tab erstellen
function WaterLib:CreateTab(name)
    local TabFrame = Instance.new("Frame", ScreenGui)
    TabFrame.Name = name .. "Tab"
    TabFrame.Size = UDim2.new(0, 160, 0, 32)
    TabFrame.Position = UDim2.new(0, 30 + (WaterLib.TabCount * 180), 0, 50)
    TabFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    TabFrame.BorderSizePixel = 0
    Instance.new("UICorner", TabFrame)
    
    local Header = Instance.new("TextLabel", TabFrame)
    Header.Size = UDim2.new(1, 0, 1, 0)
    Header.Text = name:upper()
    Header.TextColor3 = Color3.fromRGB(0, 150, 255)
    Header.Font = Enum.Font.GothamBold
    Header.BackgroundTransparency = 1
    Header.TextSize = 14

    local Container = Instance.new("Frame", TabFrame)
    Container.Name = "Container"
    Container.Position = UDim2.new(0, 0, 1, 5)
    Container.Size = UDim2.new(1, 0, 0, 0)
    Container.AutomaticSize = Enum.AutomaticSize.Y
    Container.BackgroundTransparency = 1
    
    local layout = Instance.new("UIListLayout", Container)
    layout.Spacing = UDim.new(0, 2)
    layout.Padding = Padding or UDim.new(0,0) -- Sicherung
    
    makeDraggable(TabFrame)
    WaterLib.TabCount = WaterLib.TabCount + 1
    return Container
end

-- Button erstellen
function WaterLib:AddModule(parent, text, callback)
    if not parent then return warn("Fehler: Kein Tab für Modul '"..text.."' gefunden!") end
    
    local enabled = false
    local btn = Instance.new("TextButton", parent)
    btn.Name = text
    btn.Size = UDim2.new(1, 0, 0, 28)
    btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(200, 200, 200)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 12
    btn.AutoButtonColor = false
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)

    btn.MouseButton1Click:Connect(function()
        enabled = not enabled
        btn.BackgroundColor3 = enabled and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(35, 35, 35)
        btn.TextColor3 = enabled and Color3.new(1,1,1) or Color3.fromRGB(200,200,200)
        task.spawn(function() callback(enabled) end)
    end)
end

-- Open/Close
UIS.InputBegan:Connect(function(input, gpe)
    if not gpe and input.KeyCode == Enum.KeyCode.RightShift then
        ScreenGui.Enabled = not ScreenGui.Enabled
        Blur.Enabled = ScreenGui.Enabled
        Blur.Size = ScreenGui.Enabled and 15 or 0
    end
end)

return WaterLib
