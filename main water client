local WaterLib = {}
WaterLib.TabCount = 0
local UIS = game:GetService("UserInputService")
local Lighting = game:GetService("Lighting")
local CoreGui = game:GetService("CoreGui")

-- 1. Hintergrund-Effekt (Blur)
local Blur = Instance.new("BlurEffect")
Blur.Size = 0
Blur.Enabled = false
Blur.Parent = Lighting

-- 2. Haupt-GUI Container
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "WaterClient_UI"
ScreenGui.ResetOnSpawn = false
ScreenGui.Enabled = false
ScreenGui.Parent = CoreGui

-- 3. Drag-Logik (Macht Tabs verschiebbar)
local function makeDraggable(frame)
    local dragging, dragInput, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    frame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
end

-- 4. Funktion: Tab erstellen (nebeneinander angeordnet)
function WaterLib:CreateTab(name)
    local TabFrame = Instance.new("Frame")
    TabFrame.Name = name
    -- Positioniert Tabs automatisch nebeneinander (200 Pixel Abstand)
    TabFrame.Position = UDim2.new(0, 20 + (WaterLib.TabCount * 200), 0, 20)
    TabFrame.Size = UDim2.new(0, 180, 0, 30) 
    TabFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    TabFrame.BorderSizePixel = 0
    TabFrame.Parent = ScreenGui
    
    local Header = Instance.new("TextLabel")
    Header.Size = UDim2.new(1, 0, 0, 30)
    Header.Text = name
    Header.BackgroundColor3 = Color3.fromRGB(0, 120, 255) -- Water Blue
    Header.TextColor3 = Color3.new(1, 1, 1)
    Header.Font = Enum.Font.GothamBold
    Header.Parent = TabFrame
    
    local Container = Instance.new("Frame")
    Container.Name = "Container"
    Container.Position = UDim2.new(0, 0, 0, 30)
    Container.Size = UDim2.new(1, 0, 0, 0)
    Container.AutomaticSize = Enum.AutomaticSize.Y
    Container.BackgroundTransparency = 1
    Container.Parent = TabFrame
    
    local Layout = Instance.new("UIListLayout")
    Layout.Parent = Container
    Layout.SortOrder = Enum.SortOrder.LayoutOrder
    
    makeDraggable(TabFrame)
    WaterLib.TabCount = WaterLib.TabCount + 1
    return Container
end

-- 5. Funktion: Module (Buttons) hinzufügen
function WaterLib:AddModule(parent, text, callback)
    local Enabled = false
    local Button = Instance.new("TextButton")
    Button.Size = UDim2.new(1, 0, 0, 30)
    Button.Text = text
    Button.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    Button.TextColor3 = Color3.new(0.8, 0.8, 0.8)
    Button.Font = Enum.Font.Gotham
    Button.BorderSizePixel = 0
    Button.Parent = parent

    Button.MouseButton1Click:Connect(function()
        Enabled = not Enabled
        Button.TextColor3 = Enabled and Color3.new(1, 1, 1) or Color3.new(0.8, 0.8, 0.8)
        Button.BackgroundColor3 = Enabled and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(40, 40, 40)
        callback(Enabled)
    end)
end

-- 6. Keybind: Rechts-Shift zum Öffnen/Schließen
UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.RightShift then
        ScreenGui.Enabled = not ScreenGui.Enabled
        Blur.Enabled = ScreenGui.Enabled
        Blur.Size = ScreenGui.Enabled and 15 or 0
    end
end)

return WaterLib
